root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.sh]
indent_style = tab
indent_size = 4

[Makefile]
indent_style = tab

[*.ts]
indent_size = 2

[*.tsx]
indent_size = 2

[*.json]
sort_keys = true

[*.yml]
indent_size = 2