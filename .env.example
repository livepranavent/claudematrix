# Workspace Environment Variables

# Core configuration
WORKSPACE_NAME=claude-godmode
ENVIRONMENT=development
DEBUG_MODE=true

# AI Model Configuration
PRIMARY_MODEL=claude-sonnet-4-6
FALLBACK_MODELS=claude-haiku-4-5-20251001,claude-opus-4-6
MAX_CONTEXT_TOKENS=128000

# Security Settings
API_KEY_PREFIX=cg_ # Must be 10+ chars
AUTH_METHOD=JWT
TOKEN_EXPIRY=15m
ALLOWED_ORIGINS=http://localhost:3000

# Telemetry
METRICS_ENABLED=true
ANONYMOUS_ID=auto

# Custom Workflow
AGENTS_CONCURRENCY=4
PLANNING_DEPTH=3

# Remove this line and rename to .env after configuration